{
  "uid": "bifrost-switch",
  "title": "bifrost — switch traffic",
  "tags": ["network", "snmp", "bifrost"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Inbound (bits/sec) per port",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never", "lineWidth": 1 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(interface_ifHCInOctets{host=\"bifrost\"}[$__rate_interval]) * 8",
          "legendFormat": "{{ifName}} {{ifAlias}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Outbound (bits/sec) per port",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never", "lineWidth": 1 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(interface_ifHCOutOctets{host=\"bifrost\"}[$__rate_interval]) * 8",
          "legendFormat": "{{ifName}} {{ifAlias}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Interface errors (/sec)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "custom": { "drawStyle": "line", "fillOpacity": 5, "showPoints": "never", "lineWidth": 1 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(interface_ifInErrors{host=\"bifrost\"}[$__rate_interval])",
          "legendFormat": "in {{ifName}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(interface_ifOutErrors{host=\"bifrost\"}[$__rate_interval])",
          "legendFormat": "out {{ifName}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "Link status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "options": { "showHeader": true },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "1": { "text": "up", "color": "green", "index": 0 },
                      "2": { "text": "down", "color": "red", "index": 1 }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "interface_ifOperStatus{host=\"bifrost\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "role": true,
              "host": true,
              "sysName": true,
              "ifAdminStatus": true
            },
            "renameByName": { "ifName": "Port", "ifAlias": "Description", "Value": "Status" }
          }
        }
      ]
    }
  ]
}
