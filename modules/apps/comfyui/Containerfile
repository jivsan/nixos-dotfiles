# ComfyUI for mjolnir's RTX 4060 Ti (Ada, sm_89).
#
# Unlike mimir there is no Pascal ceiling here — this tracks current torch.
# The constraints file still pins the trio so a ComfyUI bump can't silently
# swap in a CPU-only wheel from PyPI; it fails the build loudly instead.
# Build:  ./build.sh   → localhost/comfyui:<version>

FROM docker.io/library/python:3.12-slim

ARG COMFYUI_VERSION=v0.28.2
ARG IMPACT_PACK_VERSION=8.28
ARG IMPACT_SUBPACK_VERSION=1.3.4
ARG MANAGER_VERSION=4.2.2
ARG TORCH_INDEX=https://download.pytorch.org/whl/cu128

RUN apt-get update \
 && apt-get install -y --no-install-recommends git libgl1 libglib2.0-0 \
 && rm -rf /var/lib/apt/lists/*

RUN printf 'torch==2.11.0\ntorchvision==0.26.0\ntorchaudio==2.11.0\n' > /tmp/constraints.txt \
 && pip install --no-cache-dir --extra-index-url ${TORCH_INDEX} \
      -c /tmp/constraints.txt torch==2.11.0 torchvision==0.26.0 torchaudio==2.11.0

RUN git clone --depth 1 --branch ${COMFYUI_VERSION} \
      https://github.com/comfyanonymous/ComfyUI.git /app/ComfyUI \
 && pip install --no-cache-dir -c /tmp/constraints.txt -r /app/ComfyUI/requirements.txt

# Same custom nodes as mimir, so workflows move between the two hosts unchanged.
# Baked in: oci-containers recreates the container fs each start, so runtime
# ComfyUI-Manager installs do NOT survive.
RUN git clone --depth 1 --branch ${IMPACT_PACK_VERSION} \
      https://github.com/ltdrdata/ComfyUI-Impact-Pack.git \
      /app/ComfyUI/custom_nodes/ComfyUI-Impact-Pack \
 && pip install --no-cache-dir -c /tmp/constraints.txt \
      -r /app/ComfyUI/custom_nodes/ComfyUI-Impact-Pack/requirements.txt \
 && git clone --depth 1 --branch ${IMPACT_SUBPACK_VERSION} \
      https://github.com/ltdrdata/ComfyUI-Impact-Subpack.git \
      /app/ComfyUI/custom_nodes/ComfyUI-Impact-Subpack \
 && pip install --no-cache-dir -c /tmp/constraints.txt \
      -r /app/ComfyUI/custom_nodes/ComfyUI-Impact-Subpack/requirements.txt

# ComfyUI-Manager — node browser / updater.
#
# As of ComfyUI 0.28 this is a first-class integration, NOT a custom node:
# nodes.py does `import comfyui_manager` guarded by `--enable-manager` (see the
# CMD below), so the flag is what actually switches it on. Do *not* clone it
# into custom_nodes/ — Manager 4.x has no root __init__.py and ComfyUI's loader
# (spec_from_file_location on "<dir>/__init__.py") would silently fail to
# import it. Install it as a normal package instead.
#
# CAVEAT: nodes Manager *installs* at runtime land in the ephemeral container
# fs and are gone on the next start. Use it to browse and pick what you want,
# then make it permanent by adding a layer here and rebuilding.
RUN pip install --no-cache-dir -c /tmp/constraints.txt \
      comfyui-manager==${MANAGER_VERSION}

# triton (torch's JIT dep) compiles a tiny C module at CUDA init — without a
# compiler in the image the container dies with "Failed to find C compiler".
# Separate layer at the end so image rebuilds stay cached and fast.
RUN apt-get update \
 && apt-get install -y --no-install-recommends gcc libc6-dev \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /app/ComfyUI
EXPOSE 8188
# --enable-manager-legacy-ui is what actually draws the Manager button next to
# Run. Without it you get the backend but no UI: Manager 4.2.2 serves its API
# under a /v2/ prefix, while the frontend pinned by ComfyUI 0.28.2
# (comfyui-frontend-package 1.45.21) still calls the unprefixed
# `customnode/*` paths and 404s. The legacy flag registers the routes its JS
# expects and injects the UI via EXTENSION_WEB_DIRS. It implies
# --enable-manager; both are listed for clarity (they are not mutually
# exclusive — only --disable-manager-ui conflicts).
CMD ["python", "main.py", "--listen", "0.0.0.0", "--port", "8188", \
     "--enable-manager", "--enable-manager-legacy-ui"]
